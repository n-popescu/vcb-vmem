hint_tooltip = "The location of the pointer to the video buffer.

If THIS field is set to 1024, for example, the Virtual Display will go to
address 1024 in the VMem and use the value stored THERE as the
pointer to the actual location of the image to render.

This behavior makes it possible to swap the rendered image at once by
changing the buffer location (in this case stored at address 1024) to
another position in memory containing the data to a different image."
mouse_filter = 0
size_flags_horizontal = 3
custom_constants/separation = 2

